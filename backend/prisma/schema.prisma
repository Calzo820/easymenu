generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  primaryColor     String?           @default("#1d4ed8")
  logoUrl          String?
  currency         String            @default("EUR")
  isActive         Boolean           @default(true)
  plan             RestaurantPlan    @default(starter)
  settingsJson     Json?
  stripeCustomerId String?           @unique
  subscription     SaaSSubscription?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  users         User[]
  menuItems     MenuItem[]
  tables        Table[]
  orders        Order[]
  payments      PaymentTransaction[]
  tableSessions TableSession[]
  errorLogs     ErrorLog[]
  orderCounter  OrderCounter?
}

model User {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(owner)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sessions   UserSession[]
}


model UserSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MenuItem {
  id               String          @id @default(cuid())
  restaurantId     String
  name             String
  description      String?
  shortDescription String?
  price            Decimal          @db.Decimal(10, 2)
  category         String?
  imageUrl         String?
  allergens        String[]        @default([])
  sku              String?
  vatRate          Decimal          @default(10) @db.Decimal(5, 2)
  sortOrder        Int             @default(0)
  isFeatured       Boolean         @default(false)
  preparationArea  PreparationArea
  isAvailable      Boolean         @default(true)
  isDeleted        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model Table {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  code         String
  qrToken      String   @unique @default(cuid())
  seats        Int      @default(4)
  zone         String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders     Order[]
  sessions   TableSession[]

  @@unique([restaurantId, code])
}

model TableSession {
  id           String             @id @default(cuid())
  restaurantId String
  tableId      String
  status       TableSessionStatus @default(open)
  guestName    String?
  notes        String?
  totalAmount  Decimal             @default(0) @db.Decimal(10, 2)
  openedAt     DateTime           @default(now())
  closedAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      Table      @relation(fields: [tableId], references: [id], onDelete: Restrict)
  orders     Order[]
}

model Order {
  id              String         @id @default(cuid())
  restaurantId    String
  tableId         String
  tableSessionId  String?
  publicToken     String         @unique @default(cuid())
  orderNumber     Int            @default(1)
  customerName    String?
  notes           String?
  source          OrderSource    @default(qr)
  status          OrderStatus    @default(pending)
  paymentStatus   PaymentStatus  @default(unpaid)
  paymentMethod   PaymentMethod?
  clientRequestId String?
  idempotencyKey  String?        @unique
  totalAmount     Decimal        @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal        @default(0) @db.Decimal(10, 2)
  extraAmount     Decimal        @default(0) @db.Decimal(10, 2)
  acceptedAt      DateTime?
  readyAt         DateTime?
  servedAt        DateTime?
  closedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table         Table                @relation(fields: [tableId], references: [id], onDelete: Restrict)
  tableSession  TableSession?        @relation(fields: [tableSessionId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payments      PaymentTransaction[]

  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  paidAt                  DateTime?
}

model OrderItem {
  id               String           @id @default(cuid())
  orderId          String
  menuItemId       String?
  quantity         Int
  nameSnapshot     String
  priceSnapshot    Decimal          @db.Decimal(10, 2)
  categorySnapshot String?
  notes            String?
  preparationArea  PreparationArea?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
}

model PaymentTransaction {
  id                      String        @id @default(cuid())
  restaurantId            String
  orderId                 String
  provider                String        @default("stripe")
  providerSessionId       String?       @unique
  providerPaymentIntentId String?
  amount                  Decimal       @db.Decimal(10, 2)
  currency                String        @default("EUR")
  status                  PaymentStatus @default(pending)
  splitLabel              String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  paidAt                  DateTime?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderStatusHistory {
  id              String       @id @default(cuid())
  orderId         String
  fromStatus      OrderStatus?
  toStatus        OrderStatus
  changedByUserId String?
  changedByRole   String?
  note            String?
  createdAt       DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SaaSSubscription {
  id                   String             @id @default(cuid())
  restaurantId         String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 RestaurantPlan     @default(starter)
  status               SubscriptionStatus @default(trialing)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sessions   UserSession[]
}

model OrderCounter {
  restaurantId String   @id
  nextNumber   Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sessions   UserSession[]
}

enum RestaurantPlan {
  starter
  growth
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
}

enum UserRole {
  owner
  admin
  kitchen
  bar
  cashier
}

enum PreparationArea {
  kitchen
  bar
}

enum OrderStatus {
  pending
  in_progress
  ready
  served
  cancelled
}

enum TableSessionStatus {
  open
  closing
  closed
}

enum OrderSource {
  qr
  staff
  delivery
}

enum PaymentStatus {
  unpaid
  pending
  paid
  refunded
}

enum PaymentMethod {
  cash
  card
  online
  satispay
  other
}

model ErrorLog {
  id           String    @id @default(cuid())
  restaurantId String?
  level        String    @default("error")
  source       String
  message      String
  stack        String?
  metadata     Json?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([restaurantId, createdAt])
  @@index([level, createdAt])
}
