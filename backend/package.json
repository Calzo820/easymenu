{
  "name": "easymenu-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "start": "prisma generate --schema=./prisma/schema.prisma && node server.js",
    "prisma:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "check:env": "node -e \"import('./lib/env.js').then(m=>{import('dotenv').then(d=>{d.config(); console.log(m.validateEnvironment())})})\"",
    "demo:seed": "node scripts/create-demo-users.js",
    "demo:check": "node scripts/check-login-demo.js",
    "env:fix": "node scripts/fix-env-duplicates.js",
    "test:final": "node scripts/final-smoke-test.js",
    "start:prod": "prisma migrate deploy --schema=./prisma/schema.prisma && prisma generate --schema=./prisma/schema.prisma && node server.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.3",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": "20"
  }
}
